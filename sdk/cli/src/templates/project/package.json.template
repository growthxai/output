{
  "name": "{{projectName}}",
  "version": "0.0.1",
  "description": "{{description}}",
  "type": "module",
  "main": "dist/worker.js",
  "scripts": {
    "outputai:install": "npm install",
    "outputai:build": "rm -rf dist/* && tsc -p ./ && copyfiles './src/**/*.prompt' './src/**/*.yml.enc' './src/**/*.key' dist -u 1",
    "outputai:start": "output-worker",
    "outputai": "npm run outputai:install && npm run outputai:build && npm run outputai:start",
    "outputai:watch": "npx nodemon --watch src --watch package.json --ext ts,js,json,prompt --ignore 'dist/**' --ignore '**/*.test.*' --exec 'npm run outputai'",
    "dev": "output dev"
  },
  "dependencies": {
    "@outputai/output": "^{{frameworkVersion}}"
  },
  "devDependencies": {
    "@types/node": "24.5.2",
    "native-copyfiles": "2.0.1",
    "nodemon": "3.1.14",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "output": {
    "hookFiles": ["node_modules/@outputai/credentials/dist/hooks.js"]
  }
}
