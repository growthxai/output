{
  "name": "output",
  "version": "0.0.0",
  "description": "The core project that contains the SDK npm modules and the API for the output.ai framework",
  "type": "module",
  "scripts": {
    "prepare": "command -v git > /dev/null && husky || true",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.js",
    "test:e2e": "./ops/test_e2e.sh",
    "test:all": "npm test && npm run test:integration npm run test:e2e",
    "build:packages": "pnpm -r run build && cp ./api/openapi.json ./docs/guides/openapi.json",
    "dev": "npm run build:packages && npm run dev:build:api && npm run dev:up",
    "output": "./sdk/cli/bin/run.js",
    "dev:build:api": "docker build -f ops/api.Dockerfile -t outputai/api:dev .",
    "dev:up": "OUTPUT_API_VERSION=dev OUTPUT_WORKFLOWS_DIR=test_workflows npm run output -- dev --image-pull-policy missing",
    "docs:generate": "typedoc",
    "docs:validate": "typedoc --emit none"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "24.10.15",
    "eslint": "10.1.0",
    "eslint-plugin-check-file": "3.3.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "mintlify": "4.2.447",
    "native-copyfiles": "2.0.1",
    "semver": "catalog:",
    "supertest": "7.2.2",
    "typedoc": "0.28.18",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.1"
  },
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/growthxai/output-sdk"
  },
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "lint-staged": {
    "*": [
      "./ops/format_files.sh"
    ]
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser@>=4.0.0-beta.3 <=5.5.6": ">=5.5.7",
      "tar@<6.2.1": ">=6.2.1",
      "zod@<=3.22.2": ">=3.22.3",
      "body-parser@<1.20.3": ">=1.20.3",
      "serve-static@<1.16.0": ">=1.16.0",
      "express@<4.20.0": ">=4.20.0",
      "path-to-regexp@<0.1.10": ">=0.1.10",
      "cookie@<0.7.0": ">=0.7.0",
      "path-to-regexp@<0.1.12": ">=0.1.12",
      "send@<0.19.0": ">=0.19.0",
      "express@<4.19.2": ">=4.19.2",
      "axios@>=1.0.0 <1.12.0": ">=1.12.0",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "tar@<7.5.7": ">=7.5.7",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "axios@>=1.0.0 <=1.13.4": ">=1.13.5",
      "tar@<=7.5.2": ">=7.5.3",
      "tar@<7.5.8": ">=7.5.8",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "qs@<6.14.1": ">=6.14.1",
      "tar@<=7.5.9": ">=7.5.10",
      "tar@<=7.5.10": ">=7.5.11",
      "tar@<=7.5.3": ">=7.5.4"
    }
  }
}
