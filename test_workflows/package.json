{
  "name": "test_workflows",
  "version": "0.0.0",
  "description": "A simple output core abstract",
  "type": "module",
  "private": true,
  "scripts": {
    "output:worker:install": "corepack enable && CI=1 pnpm install --frozen-lockfile",
    "output:worker:build": "rm -rf dist/* && tsc && output-copy-assets",
    "output:worker:start": "output-worker",
    "output:worker": "npm run output:worker:install && npm run output:worker:build && npm run output:worker:start",
    "output:worker:watch": "npx nodemon --watch src --watch package.json --ext ts,js,json,prompt --ignore 'dist/**' --ignore '**/*.test.*' --exec 'npm run output:worker'"
  },
  "dependencies": {
    "@outputai/core": "workspace:^",
    "@outputai/credentials": "workspace:^",
    "@outputai/evals": "workspace:^",
    "@outputai/http": "workspace:^",
    "@outputai/llm": "workspace:^",
    "@temporalio/workflow": "catalog:",
    "nodemon": "3.1.14"
  },
  "output": {
    "hookFiles": [
      "./src/error_hooks.js"
    ]
  }
}
