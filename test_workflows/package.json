{
  "name": "test_workflows",
  "version": "0.0.0",
  "description": "A simple output core abstract",
  "type": "module",
  "private": true,
  "scripts": {
    "outputai:install": "corepack enable && CI=1 pnpm install --frozen-lockfile",
    "outputai:build": "rm -rf dist/* && tsc && copyfiles './src/**/*.prompt' './src/**/*.yml.enc' './src/**/*.key' dist -u 1",
    "outputai:start": "output-worker",
    "outputai": "npm run outputai:install && npm run outputai:build && npm run outputai:start",
    "outputai:watch": "npx nodemon --watch src --watch package.json --ext ts,js,json,prompt --ignore 'dist/**' --ignore '**/*.test.*' --exec 'npm run outputai'"
  },
  "dependencies": {
    "@outputai/core": "workspace:^",
    "@outputai/credentials": "workspace:^",
    "@outputai/evals": "workspace:^",
    "@outputai/http": "workspace:^",
    "@outputai/llm": "workspace:^",
    "@temporalio/workflow": "catalog:",
    "nodemon": "3.1.14"
  },
  "output": {
    "hookFiles": [
      "./src/error_hooks.js"
    ]
  }
}
